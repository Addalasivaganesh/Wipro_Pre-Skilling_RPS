from gensim.models import Word2Vec

data = [
    ["doctor","hospital"],
    ["nurse","hospital"],
    ["football","sport"],
    ["cricket","sport"]
]

model = Word2Vec(sentences=data, vector_size=5, window=2, min_count=1)

print("doctor:", model.wv["doctor"])
print("nurse:", model.wv["nurse"])


🔹 Explanation
Words converted into vectors using context

✅ Exercise 2
🔹 Question
Find similarities

🔹 Code
from gensim.models import Word2Vec

# Training data
data = [
    ["doctor", "hospital"],
    ["nurse", "hospital"],
    ["football", "sport"],
    ["cricket", "sport"]
]

# Train model
model = Word2Vec(sentences=data, vector_size=5, window=2, min_count=1)

# Similarity
print("doctor vs nurse:", model.wv.similarity("doctor", "nurse"))
print("football vs cricket:", model.wv.similarity("football", "cricket"))
print("doctor vs football:", model.wv.similarity("doctor", "football"))

🔹 Answer

Most similar → doctor & nurse
Least similar → doctor & football



✅ ✅ ✅ GloVe
✅ Exercise 1
🔹 Question
Load embeddings

🔹 Code
import numpy as np

embeddings = {}

with open("glove.6B.50d.txt", encoding="utf-8") as f:
    for line in f:
        values = line.split()
        word = values[0]
        vector = np.array(values[1:], dtype='float32')
        embeddings[word] = vector

print(len(embeddings["doctor"]))


🔹 Answer
Vector size = 50

✅ Exercise 2
🔹 Question
Find similarity

🔹 Code
import numpy as np
from numpy import dot
from numpy.linalg import norm

# Load embeddings
embeddings = {}

with open("glove.6B.50d.txt", encoding="utf-8") as f:
    for line in f:
        values = line.split()
        word = values[0]
        vector = np.array(values[1:], dtype='float32')
        embeddings[word] = vector

# Cosine similarity
def cosine(a, b):
    return dot(a, b) / (norm(a) * norm(b))

print("doctor vs nurse:", cosine(embeddings["doctor"], embeddings["nurse"]))
print("doctor vs football:", cosine(embeddings["doctor"], embeddings["football"]))

🔹 Answer

Most similar → doctor & nurse
Least → doctor & football



